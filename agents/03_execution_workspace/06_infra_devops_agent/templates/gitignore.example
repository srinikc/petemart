# =============================================================================
# PeteMart — .gitignore (Full Stack Next.js + Supabase + Expo)
# =============================================================================

# ── Dependencies ──
node_modules/
.pnp
.pnp.js

# ── Build outputs ──
.next/
out/
dist/
build/
.expo/
*.tsbuildinfo
next-env.d.ts

# ── Environment files (DO NOT COMMIT) ──
.env
.env.local
.env.production.local
.env.development.local
.env.test.local
.env.*.local

# ── IDE / Editor ──
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Coverage ──
coverage/
.nyc_output/

# ── Supabase local ──
supabase/.temp/
supabase/.branches/
supabase/.env

# ── Docker ──
docker/postgres-data/

# ── Kubernetes local ──
kubeconfig.yaml

# ── Certificates / Keys ──
*.pem
*.key
*.cert
*.p12
*.pfx

# ── OS files ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Sentry ──
.sentryclirc
