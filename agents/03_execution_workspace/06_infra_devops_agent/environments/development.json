{
  "environment": "development",
  "branch": "develop",
  "domain": "dev.petemart.vercel.app",
  "vercelProjectName": "petemart-dev",
  "supabaseProjectRef": "dev",
  "isProduction": false,
  "features": {
    "enableDebugLogging": true,
    "enableHotReload": true,
    "enableMockAuth": true,
    "bypassPaymentGateway": true,
    "enableSeedData": true
  },
  "resources": {
    "compute": "free",
    "vercelTier": "hobby",
    "supabaseTier": "free",
