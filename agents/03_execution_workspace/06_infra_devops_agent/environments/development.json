  "deployment": {
    "strategy": "rolling",
    "autoDeployOnPush": true,
    "requireApproval": false,
    "previewDeployments": true
  },
  "secrets": {
    "NEXT_PUBLIC_SUPABASE_URL": "https://dev-xxxxx.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJ...dev-anon-key"
  }
}
