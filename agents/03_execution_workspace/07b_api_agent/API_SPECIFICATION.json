  "validationSchemas": {
    "zodSchemas": {
      "signupSchema": "z.object({ email: z.string().email().optional(), phone: z.string().regex(/^\\+?[1-9]\\d{9,14}$/).optional(), password: z.string().min(6), fullName: z.string().min(1).max(100), role: z.enum(['customer', 'merchant']).default('customer') }).refine(data => data.email || data.phone)",
      "loginSchema": "z.object({ email: z.string().email().optional(), phone: z.string().regex(/^\\+?[1-9]\\d{9,14}$/).optional(), password: z.string().min(1) }).refine(data => data.email || data.phone)",
      "verifyOtpSchema": "z.object({ phone: z.string().regex(/^\\+?[1-9]\\d{9,14}$/), token: z.string().length(6), type: z.enum(['signup', 'login']) })",
      "createProductSchema": "z.object({ name: z.string().min(1).max(200), description: z.string().max(2000).optional(), price: z.number().positive(), compareAtPrice: z.number().positive().optional(), unit: z.string().default('piece'), stockQuantity: z.number().int().min(0).default(0), categoryId: z.string().uuid().optional(), images: z.array(z.string().url()).max(10).default([]), tags: z.array(z.string()).max(20).default([]), attributes: z.record(z.unknown()).default({}), isFeatured: z.boolean().default(false), preparationTimeMinutes: z.number().int().positive().optional() })",
      "updateProductSchema": "createProductSchema.partial()",
      "createMerchantSchema": "z.object({ businessName: z.string().min(1).max(200), city: z.string().min(1).max(100), ... })",
      "checkoutSchema": "z.object({ items: z.array(checkoutItemSchema).min(1).max(50), deliveryAddress: z.object({ line1: z.string().min(1), city: z.string().min(1), state: z.string().min(1), pincode: z.string().regex(/^\\d{6}$/) }), deliveryNotes: z.string().max(500).optional(), contactPhone: z.string().regex(/^\\+?[1-9]\\d{9,14}$/), paymentMethod: z.enum(['card', 'upi', 'cod', 'wallet']).default('upi') })",
      "updateOrderStatusSchema": "z.object({ status: z.enum(['confirmed', 'preparing', 'ready_for_pickup', 'out_for_delivery', 'delivered', 'cancelled']), reason: z.string().max(500).optional() })",
      "approveMerchantSchema": "z.object({ status: z.enum(['active', 'suspended']), commissionRate: z.number().min(0).max(100).optional(), notes: z.string().max(500).optional() })"
    }
  },
  "securityFramework": {
