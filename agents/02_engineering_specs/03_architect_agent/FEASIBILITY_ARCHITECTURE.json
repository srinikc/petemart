          "features": ["Pagination", "Filter by mode, market, category", "Full-text search", "Price range filter"]
        },
        "merchants": {
          "base": "/merchants",
          "methods": ["GET (list)", "GET (by slug)", "POST", "PUT"],
          "auth": "Public read, Admin write",
          "features": ["Filter by market, category, mode", "Geo-filtering", "Digital readiness score"]
        },
        "orders": {
          "base": "/orders",
          "methods": ["GET (list)", "GET (by id)", "POST", "PUT (status)"],
          "auth": "Customer (own), Merchant (their), Admin (all)",
          "features": ["Multi-merchant order creation", "Status state machine", "History + repeat order"]
        },
        "cart": {
          "base": "/cart",
          "methods": ["GET", "POST (add item)", "PUT (quantity)", "DELETE (item)", "POST (clear)"],
          "auth": "Customer (JWT) + anonymous (session_id)",
          "features": ["Multi-merchant support", "Price snapshot at add", "Delivery fee estimation"]
        },
        "checkout": {
          "base": "/checkout",
          "methods": ["POST (calculate)", "POST (place order)"],
          "auth": "Customer",
          "features": ["Delivery fee calculation", "Coupon validation", "Razorpay order creation"]
        },
        "payments": {
          "base": "/payments",
          "methods": ["POST (verify)", "POST (webhook/razorpay)", "POST (refund)"],
          "auth": "Webhook (signature verified), Customer (own)"
        },
        "auth": {
          "base": "/auth",
          "methods": ["POST (send-otp)", "POST (verify-otp)", "POST (refresh)", "POST (logout)"],
          "auth": "Public"
        },
        "tracking": {
          "base": "/tracking",
          "methods": ["POST (gps)", "GET (order/:id)"],
          "auth": "Courier (write), Customer (read)",
          "features": ["WebSocket via Supabase Realtime for live updates"]
        },
        "analytics": {
          "base": "/analytics",
          "methods": ["GET (merchant/:id)", "GET (admin)"],
          "auth": "Merchant (own), Admin (all)",
          "features": ["Date range filtering", "Export CSV/PDF"]
        },
        "admin": {
          "base": "/admin",
          "methods": ["GET (merchants)", "PUT (merchant/approve)", "GET (revenue)"],
          "auth": "Admin only"
        },
        "config": {
          "base": "/config",
          "methods": ["GET (public)", "PUT (admin)", "POST (hot-reload)"],
          "auth": "Public (reads), Admin (writes)"
        },
        "bullion": {
          "base": "/bullion",
          "methods": ["GET (rates)", "GET (history/:metal)"],
          "auth": "Public",
          "cache_ttl": "5 minutes"
        },
        "whatsapp": {
          "base": "/whatsapp",
          "methods": ["GET (deeplink)", "POST (webhook)"],
          "auth": "Public (read), Webhook (verified)"
        }
      }
    },

