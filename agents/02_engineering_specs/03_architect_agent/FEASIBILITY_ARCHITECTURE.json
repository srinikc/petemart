  "architecture_decisions": {
    "primary_decisions": [
      {
        "id": "AD-001",
        "title": "Google Stitch as Primary UI Tool",
        "decision": "Use Google Stitch MCP SDK (@google/stitch-sdk) as the ONLY UI design and prototyping tool",
        "rationale": "AI-native UI generation from NL prompts; FREE (350 std + 200 pro gens/mo); exports React code + DESIGN.md tokens; agentic MCP SDK enables programmatic pipeline integration with Agent 07a",
        "alternatives_considered": ["Figma", "Sketch", "Penpot"],
        "cost_impact": "₹0/mo"
      },
      {
        "id": "AD-002",
        "title": "Next.js 15 + shadcn/ui on Vercel",
        "decision": "Web frontend = Next.js 15 with App Router, shadcn/ui components, Tailwind CSS, deployed on Vercel Hobby (free)",
        "rationale": "SSR for SEO-critical merchant microsites; server components for performance; shadcn/ui for accessible component library; Vercel-native deployment with zero config",
        "alternatives_considered": ["React SPA + Netlify", "Nuxt 3", "SvelteKit"],
        "cost_impact": "₹0/mo (POC)"
      },
      {
        "id": "AD-003",
        "title": "Expo (React Native) + Expo Go",
        "decision": "Mobile app = Expo (React Native) with NativeWind, tested via Expo Go (no native builds for POC)",
        "rationale": "Code sharing with web (TypeScript, Tailwind); Expo Go eliminates build costs; EAS free tier for later production builds",
        "alternatives_considered": ["Flutter", "Swift/Kotlin native"],
        "cost_impact": "₹0/mo (POC)"
      },
      {
        "id": "AD-004",
        "title": "Supabase as Single Backend Platform",
        "decision": "Supabase Free provides PostgreSQL + Auth + Storage + Realtime + Edge Functions — single platform for entire backend",
        "rationale": "Eliminates multiple backend services; free tier is generous (500MB DB, 50K users, 1GB storage, 200 realtime conns); RLS provides multi-tenancy out of the box; realtime enables live order tracking",
        "alternatives_considered": ["Firebase", "AWS Amplify", "Appwrite"],
        "cost_impact": "₹0/mo (POC)"
      },
      {
        "id": "AD-005",
        "title": "API-First Architecture",
        "decision": "All frontends (Web, Mobile, Courier App) consume the same RESTful API layer from Next.js API Routes + Supabase Edge Functions",
        "rationale": "Single contract for all clients; versioned endpoints (/api/v1/); enables independent frontend evolution; simplifies testing",
        "alternatives_considered": ["GraphQL", "tRPC", "BFF pattern"],
        "cost_impact": "Neutral"
      },
      {
        "id": "AD-006",
        "title": "PostgreSQL Full-Text Search (POC), Meilisearch (Production)",
        "decision": "Start with PostgreSQL FTS for POC search; upgrade to Meilisearch for production at 500+ merchants",
        "rationale": "PgFTS is free in Supabase, sufficient for 8 merchants; Meilisearch provides typo-tolerance, faceted search, and sub-50ms response for 5,000+ merchants",
        "alternatives_considered": ["Algolia", "Elasticsearch"],
        "cost_impact": "₹0/mo (POC), ~₹2,500/mo (Production)"
      },
      {
        "id": "AD-007",
        "title": "Razorpay Test Mode for POC Payments",
        "decision": "Use Razorpay test mode API keys for POC; no real money moved; full KYC + production mode at launch",
        "rationale": "Razorpay is India's dominant PG; test mode is free; subaccount Route API enables merchant payout model; PCI DSS scope reduction (SAQ A)",
        "alternatives_considered": ["Stripe", "Cashfree", "PayU"],
        "cost_impact": "₹0/mo (POC)"
      },
      {
        "id": "AD-008",
        "title": "Google Gemini Free for AI Features",
        "decision": "Use Google Gemini API free tier for AI features (search relevance, content generation, basic image analysis)",
        "rationale": "Free tier: 60 requests/min, 1,500/day; superior multilingual support for Kannada/Hindi; integrates with Stitch design-to-code workflow",
        "alternatives_considered": ["OpenAI", "Claude", "Replicate"],
        "cost_impact": "₹0/mo (POC)"
      }
    ]
  },

