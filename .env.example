# =============================================================================
# PeteMart — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# =============================================================================
# NEVER commit .env or .env.local to git. Only .env.example is committed.
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── DeepSeek API (for AI code review pre-commit hook) ──────────────────────
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── QA Dashboard ───────────────────────────────────────────────────────────
# Set to "true" to disable the QA run API in production
BLOCK_QA_API=false

# ── Next.js ────────────────────────────────────────────────────────────────
NODE_ENV=development
