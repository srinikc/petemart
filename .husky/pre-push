#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

BRANCH=$(git symbolic-ref HEAD 2>/dev/null | cut -d'/' -f3-)
PROTECTED_BRANCHES="develop main"

for protected in $PROTECTED_BRANCHES; do
  if [ "$BRANCH" = "$protected" ]; then
    echo ""
    echo "  ✖ Direct push to '$BRANCH' is BLOCKED."
    echo "  ─────────────────────────────────────────────"
    echo "  You must push a FEATURE BRANCH and create a Pull Request to '$BRANCH'."
    echo ""
    echo "  Workflow:"
    echo "    git checkout -b feature/your-feature-name develop"
    echo "    # make your changes"
    echo "    git add . && git commit   # pre-commit hook runs: AI review → tsc → tests"
    echo "    git push origin feature/your-feature-name"
    echo "    gh pr create --base $BRANCH --title \"Your title\" --body \"Description\""
    echo ""
    echo "  To bypass (emergency only): git push origin $BRANCH --no-verify"
    echo ""
    exit 1
  fi
done

exit 0
