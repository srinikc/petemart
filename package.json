{
  "name": "petemart-unified",
  "version": "1.0.0",
  "description": "PeteMart — Unified Next.js App (UI + API + DB integration)",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui --open",
    "test:api": "jest --passWithNoTests --forceExit --detectOpenHandles",
    "qa:collect": "node scripts/collect-test-results.js",
    "qa:full": "npm test && npm run qa:collect",
    "qa:report": "vitest run --reporter=json --outputFile=qa-dashboard/vitest-output.json && node scripts/collect-test-results.js",
    "qa:dashboard": "vitest --ui",
    "qa:run": "node scripts/run-tests.js",
    "qa:run:ci": "node scripts/run-tests.js --env=ci",
    "qa:sanity": "node scripts/run-tests.js --tier=sanity",
    "qa:full": "node scripts/run-tests.js --tier=full",
    "qa:release": "node scripts/run-tests.js --tier=release",
    "qa:list": "node scripts/run-tests.js --list",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "e2e:debug": "npx playwright test --debug",
    "e2e:report": "npx playwright show-report qa-dashboard/playwright-report",
    "e2e:install": "npx playwright install --with-deps",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:db:migrate": "npx supabase db push",
    "supabase:db:seed": "npx supabase db execute --file supabase/seed.sql",
    "supabase:db:reset": "npx supabase db reset",
    "supabase:types": "npx supabase gen types typescript --local > types/supabase.ts",
    "db:migrate": "psql -h localhost -U postgres -d petemart -f supabase/migrations/001_initial_schema.sql && psql -h localhost -U postgres -d petemart -f supabase/migrations/002_rls_policies.sql && psql -h localhost -U postgres -d petemart -f supabase/migrations/003_auth_triggers.sql",
    "db:seed": "psql -h localhost -U postgres -d petemart -f supabase/seed.sql",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "setup": "npm install && npm run db:setup",
    "qa:start": "powershell -NoProfile -File scripts/serve-qa-dashboard.ps1",
    "qa:stop": "powershell -NoProfile -File scripts/stop-qa-dashboard.ps1",
    "serve:qa": "npx next start -p 3458",
    "qa:start": "powershell -File scripts/serve-qa-dashboard.ps1",
    "qa:stop": "powershell -File scripts/stop-qa-dashboard.ps1",
    "serve:qa:standalone": "node .next/standalone/server.js -p 3458",
    "docker:build": "docker build -t petemart-unified .",
    "docker:run": "docker run -p 3000:3000 petemart-unified",
    "vercel:deploy": "vercel --prod",
    "railway:deploy": "railway up",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "precommit": "lint-staged && tsc --noEmit && npm test"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx tsc --noEmit --pretty 2>NUL || cd ."
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.460.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.14.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.0",
    "zod-validation-error": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^17.0.7",
    "postcss": "^8.4.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
